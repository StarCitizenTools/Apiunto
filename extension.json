{
	"name": "Apiunto",
	"version": "3.0.0",
	"author": [
		"[https://www.mediawiki.org/wiki/User:Octfx Octfx]",
		"[https://www.mediawiki.org/wiki/User:Alistair3149 Alistair3149]"
	],
	"url": "https://github.com/StarCitizenTools/mediawiki-extensions-Apiunto",
	"descriptionmsg": "apiunto-desc",
	"license-name": "MIT",
	"type": "other",
	"requires": {
		"MediaWiki": ">= 1.43.0",
		"extensions": {
			"Scribunto": "*"
		}
	},
	"MessagesDirs": {
		"Apiunto": [
			"i18n"
		]
	},
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\Apiunto\\": "src/",
		"MediaWiki\\Extension\\Apiunto\\Maintenance\\": "maintenance/"
	},
	"config": {
		"ApiuntoSources": {
			"value": [],
			"description": "An array of API sources. Each source has a baseUrl, token, timeout, and cacheDuration."
		},
		"ApiuntoEnableCache": {
			"description": "Save api responses in cache",
			"value": true
		}
	},
	"HookHandlers": {
		"ActionHooks": {
			"class": "MediaWiki\\Extension\\Apiunto\\Hooks\\ActionHooks",
			"services": [
				"PageProps",
				"Apiunto.CacheInfoResolver"
			]
		},
		"PurgeHooks": {
			"class": "MediaWiki\\Extension\\Apiunto\\Hooks\\PurgeHooks",
			"services": [
				"Apiunto.CachePurger"
			]
		},
		"ScribuntoHooks": {
			"class": "MediaWiki\\Extension\\Apiunto\\Hooks\\ScribuntoHooks"
		}
	},
	"Hooks": {
		"ArticlePurge": "PurgeHooks",
		"InfoAction": "ActionHooks",
		"ScribuntoExternalLibraries": "ScribuntoHooks"
	},
	"ServiceWiringFiles": [
		"src/ServiceWiring.php"
	],
	"manifest_version": 2
}
